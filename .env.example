# =============================================================================
# Enterprise RAG Document Engine - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword123
POSTGRES_DB=ragengine
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# MinIO Configuration
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=documents

# -----------------------------------------------------------------------------
# Qdrant Configuration
# -----------------------------------------------------------------------------
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# Set this in production for API authentication
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documents

# -----------------------------------------------------------------------------
# Embedding Model Configuration
# -----------------------------------------------------------------------------
# HuggingFace model for document embeddings
# all-MiniLM-L6-v2: Fast, good quality, 384 dimensions
# all-mpnet-base-v2: Higher quality, 768 dimensions, slower
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# -----------------------------------------------------------------------------
# LLM Configuration (for RAG chat)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4-turbo-preview

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend Configuration (for Phase 2)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
